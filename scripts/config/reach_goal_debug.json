{
    "env": {
        "id": "goal-safe-v0",
        "max_episode_steps": 50,
        "grid_size": 5,
        "num_humans": 5,
        "step_penalty": 0.3,
        "terminal_reward": 1,
        "obs_as_grid": false
    },
    "train": {
        "total_timesteps": 500,
        "eval_freq": 100,
        "num_eval_weights_for_front": 50,
        "num_eval_episodes_for_front": 5,
        "num_eval_weights_for_eval": 25
    },
    "eval": {
        "num_eval_episodes": 5,
        "num_eval_weights": 25,
        "out_dir": "results/reach_goal/debug"
    },
    "agent": {
        "seed": 42,
        "learning_rate": 0.001,
        "net_arch": [
            128,
            128
        ],
        "batch_size": 64,
        "learning_starts": 50,
        "gradient_updates": 1,
        "target_net_update_freq": 50,
        "log": true,
        "cnn_config": {
            "out_features": 64,
            "channels": [3, 16, 32],
            "kernels": [3, 3],
            "strides": [1,1],
            "paddings": [1, 0]
        }
    }
}