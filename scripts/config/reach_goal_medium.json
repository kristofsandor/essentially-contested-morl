{
    "env": {
        "id": "goal-safe-v0",
        "max_episode_steps": 200,
        "grid_size": 10,
        "num_humans": 20,
        "step_penalty": 0.4,
        "terminal_reward": 3,
        "obs_as_grid": false
    },
    "train": {
        "total_timesteps": 500000,
        "eval_freq": 10000,
        "num_eval_weights_for_front": 50,
        "num_eval_episodes_for_front": 5,
        "num_eval_weights_for_eval": 25
    },
    "eval": {
        "num_eval_episodes": 5,
        "num_eval_weights": 25,
        "out_dir": "results/reach_goal/pareto_front_medium"
    },
    "agent": {
        "seed": 42,
        "learning_rate": 0.0003,
        "initial_epsilon": 1.0,
        "final_epsilon": 0.1,
        "epsilon_decay_steps": 100000,
        "net_arch": [
            128,
            128
        ],
        "batch_size": 64,
        "learning_starts": 2000,
        "gradient_updates": 1,
        "target_net_update_freq": 500,
        "num_sample_w": 8,
        "log": true
    }
}