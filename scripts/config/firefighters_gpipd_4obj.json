{
    "general": {
        "use_ecc": false,
        "eval_both_interps": false
    },
    "env": {
        "id": "firefighters-mo-ecc-v0",
        "horizon": 50,
        "interpretations": [
            ["pf_rescue", "px_people"],
            ["pf_fire", "px_fire"]
        ],
        "interpretation_labels": ["rescue_minded", "fire_minded"]
    },
    "train": {
        "ref_point": [0.0, 0.0, 0.0, 0.0],
        "total_timesteps": 50000,
        "weight_selection_algo": "gpi-ls",
        "timesteps_per_iter": 5000,
        "eval_freq": 25,
        "eval_mo_freq": 25,
        "num_eval_weights_for_front": 25,
        "num_eval_episodes_for_front": 5,
        "num_eval_weights_for_eval": 25,
        "num_checkpoints": 3
    },
    "eval": {
        "num_eval_episodes": 50,
        "num_eval_weights": 50
    },
    "agent": {
        "algorithm": "gpi_pd",
        "seed": 42,
        "learning_rate": 3e-4,
        "gamma": 0.98,
        "net_arch": [
            128,
            128,
            128
        ],
        "batch_size": 128,
        "buffer_size": 100000,
        "learning_starts": 0,
        "gradient_updates": 10,
        "target_net_update_freq": 500,
        "tau": 1.0,
        "max_grad_norm": 10.0,
        "num_nets": 2,
        "drop_rate": 0.01,
        "layer_norm": true,
        "initial_epsilon": 1.0,
        "final_epsilon": 0.0,
        "epsilon_decay_steps": 25000,
        "use_gpi": true,
        "per": true,
        "alpha_per": 0.6,
        "min_priority": 0.01,
        "gpi_pd": true,
        "dyna": false,
        "real_ratio": 0.5,
        "log": true,
        "experiment_name": "firefighters_gpipd_4obj"
    }
}
