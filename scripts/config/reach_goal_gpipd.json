{
    "env": {
        "id": "goal-safe-v0",
        "max_episode_steps": 25,
        "grid_size": 5,
        "num_humans": 5,
        "help_reward": 1,
        "step_penalty": 0.25,
        "terminal_reward": 2,
        "proximity_reward": 0.05,
        "obs_as_grid": false
    },
    "train": {
        "total_timesteps": 50000,
        "weight_selection_algo": "gpi-ls", 
        "timesteps_per_iter": 5000, 
        "eval_freq": 5000,
        "eval_mo_freq": 5000,
        "num_eval_weights_for_front": 25,
        "num_eval_episodes_for_front": 5,
        "num_eval_weights_for_eval": 25,
        "num_checkpoints": 3
    },
    "eval": {
        "num_eval_episodes": 50,
        "num_eval_weights": 50
    },
    "agent": {
        "algorithm": "gpi_pd",
        "seed": 42,
        
        "learning_rate": 3e-4, 
        "gamma": 0.98, 
        "net_arch": [
            64,
            64
        ], 
        "batch_size": 128,
        "buffer_size": 50000, 
        "learning_starts": 1000,
        "gradient_updates": 10, 
        "target_net_update_freq": 1000,
        "tau": 1.0,
        "max_grad_norm": 10.0,
        "num_nets": 2,
        "drop_rate": 0.01,
        "layer_norm": true,
        
        "initial_epsilon": 1.0,
        "final_epsilon": 0.05,
        "epsilon_decay_steps": 15000, 
        
        "use_gpi": true,
        "per": true,
        "alpha_per": 0.6,
        "min_priority": 0.01,
        "gpi_pd": true, 
        "dyna": false,
        
        "dynamics_rollout_starts": 5000,
        "dynamics_rollout_freq": 250,
        "dynamics_rollout_len": 1,
        "dynamics_rollout_batch_size": 5000, 
        "dynamics_net_arch": [
            64,
            64
        ],
        "dynamics_ensemble_size": 5,
        "dynamics_num_elites": 2,
        "real_ratio": 0.5,
        "log": true
    }
}