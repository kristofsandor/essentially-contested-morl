Bootstrap: docker
From: ubuntu:22.04

%labels
    Author kristofasandor
    Description Apptainer environment for the md-morl project, Python 3.12

%post
    apt-get update && apt-get install -y curl git build-essential libgmp-dev && apt-get clean

    # install uv to a system location
    curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR="/usr/local/bin" sh

    # keep the managed Python and venv in /opt so a mounted $HOME cannot shadow them
    export UV_PYTHON_INSTALL_DIR=/opt/uv/python
    uv python install 3.12
    uv venv /opt/venv --python 3.12
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"

    # dependencies
    uv pip install pycddlib-standalone
    uv pip install torch==2.6.0 --index-url https://download.pytorch.org/whl/cu124
    uv pip install gymnasium mo-gymnasium tqdm numpy matplotlib pymoo wandb seals \
        ipywidgets cvxpy fire imageio moviepy pygame scipy seaborn sortedcontainers
    uv pip install git+https://github.com/LucasAlegre/morl-baselines.git --no-deps

    # create bind-mount points so -B targets exist inside the image
    mkdir -p /project-storage

%environment
    export PYTHONUNBUFFERED=1
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"
    export UV_PYTHON_INSTALL_DIR=/opt/uv/python

%runscript
    exec /opt/venv/bin/python "$@"
