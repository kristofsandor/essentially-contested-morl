Bootstrap: docker
From: ubuntu:22.04

%labels
    Author kristofasandor
    Description Apptainer image for running run_code/gpipd_four_room.py with Python 3.12

%files
    requirements.txt /app/requirements.txt
    run_code/gpipd_four_room.py /app/run_code/gpipd_four_room.py
    env /app/env
    utils /app/utils
    wrappers /app/wrappers

%post
    apt-get update && apt-get install -y curl git build-essential libgmp-dev && apt-get clean
    
    # install uv
    curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR="/usr/local/bin" sh

    uv python install 3.12

    # create venv explicitly
    uv venv /app/.venv --python 3.12
    export VIRTUAL_ENV=/app/.venv
    export PATH="/app/.venv/bin:$PATH"

    # install deps
    uv pip install pycddlib-standalone 
    uv pip install torch==2.6.0 --index-url https://download.pytorch.org/whl/cu124
    uv pip install gymnasium mo-gymnasium tqdm numpy matplotlib pymoo wandb ipywidgets cvxpy fire imageio moviepy pygame pymoo scipy seaborn sortedcontainers torch wandb
    uv pip install git+https://github.com/LucasAlegre/morl-baselines.git --no-deps

%environment
    export PYTHONUNBUFFERED=1
    export PYTHONPATH=/app
    export VIRTUAL_ENV=/app/.venv
    export PATH="/root/.local/bin:/app/.venv/bin:$PATH"

%runscript
    exec uv run python /app/run_code/gpipd_four_room.py "$@"